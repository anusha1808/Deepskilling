BEGIN
  FOR c in (SELECT c.CustomerID, c.Name, l.LoanID FROM Customers c JOIN Loans l ON c.CustomerID = l.CustomerID WHERE l.EndDate BETWEEN SYSDATE AND SYSDATE + 30) LOOP
    dbms_output.put_line('Dear customer' || c.name || ' with id ' || c.CustomerID || 'your loan with loan id ' || c.LoanID || ' is due within 30 days.');
  END LOOP;
END;
